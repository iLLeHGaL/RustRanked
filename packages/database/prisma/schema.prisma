generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Discord (primary auth)
  discordId     String    @unique
  discordName   String
  discordAvatar String?

  // Steam (linked account)
  steamId       String?   @unique
  steamName     String?
  steamAvatar   String?

  // Contact
  email         String?

  // Verification
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verificationId     String?            // Stripe Identity verification session ID
  verifiedAt         DateTime?

  // Stripe
  stripeCustomerId String? @unique

  // Relations
  subscription  Subscription?   // @deprecated - use vipAccess instead
  vipAccess     VipAccess[]
  sessions      Session[]
  bans          Ban[]
  votes         Vote[]
  identityFingerprint IdentityFingerprint?
  flagsAsNew          IdentityFlag[] @relation("flaggedUser")
  flagsAsExisting     IdentityFlag[] @relation("matchedUser")

  // Profile
  profileViews  Int  @default(0)

  // Friends
  friendRequestsSent     Friendship[] @relation("friendRequestsSent")
  friendRequestsReceived Friendship[] @relation("friendRequestsReceived")
  topFriends             TopFriend[]  @relation("topFriends")
  topFriendOf            TopFriend[]  @relation("topFriendOf")

  @@index([discordId])
  @@index([steamId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// SUBSCRIPTION & PAYMENTS
// ============================================

// @deprecated - kept for backward compatibility with in-flight webhooks
model Subscription {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe
  stripeSubscriptionId String  @unique
  stripePriceId        String
  status               SubscriptionStatus

  // Billing
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)

  @@index([status])
}

enum VipType {
  MONTHLY
  WIPE
}

enum VipStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

model VipAccess {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  serverId             String
  server               GameServer @relation(fields: [serverId], references: [id])

  type                 VipType
  status               VipStatus @default(ACTIVE)

  stripeSubscriptionId String?   @unique  // Only for MONTHLY
  stripePaymentId      String?   @unique  // Only for WIPE

  expiresAt            DateTime
  cancelAtPeriodEnd    Boolean   @default(false)

  @@index([userId])
  @@index([serverId])
  @@index([status])
}

// ============================================
// GAME SERVERS
// ============================================

model GameServer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?
  slug        String   @unique  // URL-friendly: "us-main", "eu-small"

  // Display metadata
  region       String             // "US", "EU", "SEA"
  category     String             // "Main", "Monthly", "Biweekly", etc.
  teamLimit    Int?               // null = unlimited
  wipeSchedule String  @default("") // "Thursdays 2pm EST"
  mapSize      Int?               // 3500, 4250, etc.
  maxPlayers   Int     @default(250)
  displayOrder Int     @default(0)
  isPublic     Boolean @default(true)
  connectUrl   String?            // steam://connect/ip:port

  // Connection
  ip          String
  port        Int
  rconPort    Int?

  // Auth
  apiKeyHash  String   @unique  // Hashed API key for server auth

  // Status
  isActive    Boolean  @default(true)
  lastSeen    DateTime?

  // Relations
  vipAccesses VipAccess[]
  trophies    Trophy[]

  @@unique([ip, port])
}

// ============================================
// MODERATION
// ============================================

model Ban {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  reason      String
  bannedBy    String    // Admin user ID or "SYSTEM"
  expiresAt   DateTime? // null = permanent
  isActive    Boolean   @default(true)

  @@index([userId])
  @@index([isActive])
}

// ============================================
// ENUMS
// ============================================

enum VerificationStatus {
  UNVERIFIED  // No verification attempted
  PENDING     // Verification in progress
  VERIFIED    // Successfully verified
  REJECTED    // Verification failed
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum ServerType {
  US_MAIN
  US_MONDAYS
  EU_MAIN
  EU_MONDAYS
}

// ============================================
// MAP VOTING
// ============================================

model MapOption {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?
  imageUrl    String?

  // Relations
  votes         Vote[]
  votingPeriods VotingPeriodMap[]

  @@index([name])
}

model VotingPeriod {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Which server this voting is for
  serverType  ServerType

  // Voting window
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean    @default(false)

  // Wipe info
  wipeDate    DateTime?

  // Created by admin
  createdBy   String

  // Relations
  mapOptions  VotingPeriodMap[]
  votes       Vote[]

  @@index([serverType])
  @@index([isActive])
  @@index([startsAt, endsAt])
}

model VotingPeriodMap {
  id              String       @id @default(cuid())

  votingPeriodId  String
  votingPeriod    VotingPeriod @relation(fields: [votingPeriodId], references: [id], onDelete: Cascade)

  mapOptionId     String
  mapOption       MapOption    @relation(fields: [mapOptionId], references: [id], onDelete: Cascade)

  @@unique([votingPeriodId, mapOptionId])
}

model Vote {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())

  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  votingPeriodId  String
  votingPeriod    VotingPeriod @relation(fields: [votingPeriodId], references: [id], onDelete: Cascade)

  mapOptionId     String
  mapOption       MapOption    @relation(fields: [mapOptionId], references: [id], onDelete: Cascade)

  // User can only vote once per voting period
  @@unique([userId, votingPeriodId])
  @@index([votingPeriodId])
  @@index([mapOptionId])
}

// ============================================
// WIPE STATS (from game server plugin)
// ============================================

model WipeStats {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Player identification
  steamId         String

  // Server and wipe identification
  serverType      String     // Server slug (e.g., "us-main", "eu-small") — was ServerType enum
  wipeId          String     // Identifier for the wipe (e.g., "2024-01-15")

  // PvP
  kills             Int      @default(0)
  deaths            Int      @default(0)
  headshots         Int      @default(0)
  bulletsFired      Int      @default(0)
  bulletsHit        Int      @default(0)
  arrowsFired       Int      @default(0)
  arrowsHit         Int      @default(0)
  suicides          Int      @default(0)
  timesWounded      Int      @default(0)
  woundedRecoveries Int      @default(0)
  syringesUsed      Int      @default(0)
  bandagesUsed      Int      @default(0)
  medkitsUsed       Int      @default(0)

  // PvE
  animalKills       Int      @default(0)
  npcKills          Int      @default(0)

  // Raiding / Boom
  rocketsLaunched   Int      @default(0)
  explosivesUsed    Int      @default(0)   // Total (C4 + satchels + legacy)
  c4Used            Int      @default(0)
  satchelsUsed      Int      @default(0)
  explosiveAmmoUsed Int      @default(0)

  // Farming / Resources
  woodGathered      Int      @default(0)
  stoneGathered     Int      @default(0)
  metalOreGathered  Int      @default(0)
  sulfurOreGathered Int      @default(0)

  // Building
  blocksPlaced      Int      @default(0)
  blocksUpgraded    Int      @default(0)

  // Looting
  cratesLooted      Int      @default(0)
  barrelsLooted     Int      @default(0)

  // Recycling
  itemsRecycled     Int      @default(0)

  // Gambling
  scrapGambled      Int      @default(0)
  scrapWon          Int      @default(0)

  // Vehicles
  boatsSpawned      Int      @default(0)
  minisSpawned      Int      @default(0)

  // Vehicle Combat
  vehicleKills      Int      @default(0)

  // Fishing
  fishCaught        Int      @default(0)

  // General
  hoursPlayed       Float    @default(0)
  resourcesGathered Int      @default(0)   // total

  // Each player has one stats entry per server per wipe
  @@unique([steamId, serverType, wipeId])
  @@index([steamId])
  @@index([serverType, wipeId])
}

// ============================================
// IDENTITY ANTI-CHEAT
// ============================================

model IdentityFingerprint {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprintHash String
  documentIdHash  String?
  verificationId  String

  @@index([fingerprintHash])
  @@index([documentIdHash])
}

model IdentityFlag {
  id            String             @id @default(cuid())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  flaggedUserId String
  flaggedUser   User               @relation("flaggedUser", fields: [flaggedUserId], references: [id])
  matchedUserId String
  matchedUser   User               @relation("matchedUser", fields: [matchedUserId], references: [id])
  matchType     IdentityMatchType
  status        IdentityFlagStatus @default(PENDING)
  resolvedBy    String?
  resolvedAt    DateTime?
  resolution    String?

  @@index([status])
  @@index([flaggedUserId])
  @@index([matchedUserId])
}

enum IdentityMatchType {
  NAME_DOB
  DOCUMENT_ID
  BOTH
}

enum IdentityFlagStatus {
  PENDING
  CONFIRMED_ALT
  FALSE_POSITIVE
  AUTO_BANNED
}

// ============================================
// TROPHIES
// ============================================

model Trophy {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now())
  steamId   String
  serverId  String
  server    GameServer     @relation(fields: [serverId], references: [id])
  wipeId    String
  category  TrophyCategory
  rank      Int            // 1, 2, or 3
  statValue Int            // actual value achieved

  @@unique([steamId, serverId, wipeId, category])
  @@index([steamId])
}

enum TrophyCategory {
  MOST_KILLS
  MOST_RESOURCES
  MOST_GAMBLING_PROFIT
}

// ============================================
// FRIENDS
// ============================================

model Friendship {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  requesterId String
  requester   User             @relation("friendRequestsSent", fields: [requesterId], references: [id])
  addresseeId String
  addressee   User             @relation("friendRequestsReceived", fields: [addresseeId], references: [id])
  status      FriendshipStatus @default(PENDING)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ============================================
// TOP FRIENDS
// ============================================

model TopFriend {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation("topFriends", fields: [userId], references: [id], onDelete: Cascade)
  friendId  String
  friend    User     @relation("topFriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  position  Int      // 1-5

  @@unique([userId, friendId])
  @@unique([userId, position])
  @@index([userId])
}
