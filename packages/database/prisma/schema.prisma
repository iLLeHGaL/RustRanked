generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Discord (primary auth)
  discordId     String    @unique
  discordName   String
  discordAvatar String?

  // Steam (linked account)
  steamId       String?   @unique
  steamName     String?
  steamAvatar   String?

  // Contact
  email         String?

  // Verification
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verificationId     String?            // Stripe Identity verification session ID
  verifiedAt         DateTime?

  // Stripe
  stripeCustomerId String? @unique

  // Relations
  subscription  Subscription?   // @deprecated - use vipAccess instead
  vipAccess     VipAccess[]
  sessions      Session[]
  bans          Ban[]
  votes         Vote[]
  identityFingerprint IdentityFingerprint?
  flagsAsNew          IdentityFlag[] @relation("flaggedUser")
  flagsAsExisting     IdentityFlag[] @relation("matchedUser")

  // Economy & Battle Pass relations
  tokenBalance       TokenBalance?
  tokenTransactions  TokenTransaction[]
  playerSeasons      PlayerSeason[]
  xpEvents           XpEvent[]
  playerChallenges   PlayerChallenge[]
  inventory          PlayerInventory[]
  caseOpenings       CaseOpening[]
  shopPurchases      ShopPurchase[]
  spinResults        SpinWheelResult[]
  creator            Creator?
  streamProtection   StreamProtection?

  @@index([discordId])
  @@index([steamId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// SUBSCRIPTION & PAYMENTS
// ============================================

// @deprecated - kept for backward compatibility with in-flight webhooks
model Subscription {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe
  stripeSubscriptionId String  @unique
  stripePriceId        String
  status               SubscriptionStatus

  // Billing
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)

  @@index([status])
}

enum VipType {
  MONTHLY
  WIPE
}

enum VipStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

model VipAccess {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  serverId             String
  server               GameServer @relation(fields: [serverId], references: [id])

  type                 VipType
  status               VipStatus @default(ACTIVE)

  stripeSubscriptionId String?   @unique  // Only for MONTHLY
  stripePaymentId      String?   @unique  // Only for WIPE

  expiresAt            DateTime
  cancelAtPeriodEnd    Boolean   @default(false)

  @@index([userId])
  @@index([serverId])
  @@index([status])
}

// ============================================
// GAME SERVERS
// ============================================

model GameServer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?
  slug        String   @unique  // URL-friendly: "us-main", "eu-small"

  // Display metadata
  region       String             // "US", "EU", "SEA"
  category     String             // "Main", "Monthly", "Biweekly", etc.
  teamLimit    Int?               // null = unlimited
  wipeSchedule String  @default("") // "Thursdays 2pm EST"
  mapSize      Int?               // 3500, 4250, etc.
  maxPlayers   Int     @default(250)
  displayOrder Int     @default(0)
  isPublic     Boolean @default(true)
  connectUrl   String?            // steam://connect/ip:port

  // Connection
  ip          String
  port        Int
  rconPort    Int?

  // Auth
  apiKeyHash  String   @unique  // Hashed API key for server auth

  // Status
  isActive    Boolean  @default(true)
  lastSeen    DateTime?

  // Relations
  vipAccesses VipAccess[]

  @@unique([ip, port])
}

// ============================================
// MODERATION
// ============================================

model Ban {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  reason      String
  bannedBy    String    // Admin user ID or "SYSTEM"
  expiresAt   DateTime? // null = permanent
  isActive    Boolean   @default(true)

  @@index([userId])
  @@index([isActive])
}

// ============================================
// ENUMS
// ============================================

enum VerificationStatus {
  UNVERIFIED  // No verification attempted
  PENDING     // Verification in progress
  VERIFIED    // Successfully verified
  REJECTED    // Verification failed
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum ServerType {
  US_MAIN
  US_MONDAYS
  EU_MAIN
  EU_MONDAYS
}

// ============================================
// MAP VOTING
// ============================================

model MapOption {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?
  imageUrl    String?

  // Relations
  votes         Vote[]
  votingPeriods VotingPeriodMap[]

  @@index([name])
}

model VotingPeriod {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Which server this voting is for
  serverType  ServerType

  // Voting window
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean    @default(false)

  // Wipe info
  wipeDate    DateTime?

  // Created by admin
  createdBy   String

  // Relations
  mapOptions  VotingPeriodMap[]
  votes       Vote[]

  @@index([serverType])
  @@index([isActive])
  @@index([startsAt, endsAt])
}

model VotingPeriodMap {
  id              String       @id @default(cuid())

  votingPeriodId  String
  votingPeriod    VotingPeriod @relation(fields: [votingPeriodId], references: [id], onDelete: Cascade)

  mapOptionId     String
  mapOption       MapOption    @relation(fields: [mapOptionId], references: [id], onDelete: Cascade)

  @@unique([votingPeriodId, mapOptionId])
}

model Vote {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())

  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  votingPeriodId  String
  votingPeriod    VotingPeriod @relation(fields: [votingPeriodId], references: [id], onDelete: Cascade)

  mapOptionId     String
  mapOption       MapOption    @relation(fields: [mapOptionId], references: [id], onDelete: Cascade)

  // User can only vote once per voting period
  @@unique([userId, votingPeriodId])
  @@index([votingPeriodId])
  @@index([mapOptionId])
}

// ============================================
// WIPE STATS (from game server plugin)
// ============================================

model WipeStats {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Player identification
  steamId         String

  // Server and wipe identification
  serverType      String     // Server slug (e.g., "us-main", "eu-small") — was ServerType enum
  wipeId          String     // Identifier for the wipe (e.g., "2024-01-15")

  // PvP
  kills             Int      @default(0)
  deaths            Int      @default(0)
  headshots         Int      @default(0)
  bulletsFired      Int      @default(0)
  bulletsHit        Int      @default(0)
  arrowsFired       Int      @default(0)
  arrowsHit         Int      @default(0)
  suicides          Int      @default(0)
  timesWounded      Int      @default(0)
  woundedRecoveries Int      @default(0)
  syringesUsed      Int      @default(0)
  bandagesUsed      Int      @default(0)
  medkitsUsed       Int      @default(0)

  // PvE
  animalKills       Int      @default(0)
  npcKills          Int      @default(0)

  // Raiding / Boom
  rocketsLaunched   Int      @default(0)
  explosivesUsed    Int      @default(0)   // Total (C4 + satchels + legacy)
  c4Used            Int      @default(0)
  satchelsUsed      Int      @default(0)
  explosiveAmmoUsed Int      @default(0)

  // Farming / Resources
  woodGathered      Int      @default(0)
  stoneGathered     Int      @default(0)
  metalOreGathered  Int      @default(0)
  sulfurOreGathered Int      @default(0)

  // Building
  blocksPlaced      Int      @default(0)
  blocksUpgraded    Int      @default(0)

  // Looting
  cratesLooted      Int      @default(0)
  barrelsLooted     Int      @default(0)

  // Recycling
  itemsRecycled     Int      @default(0)

  // Gambling
  scrapGambled      Int      @default(0)
  scrapWon          Int      @default(0)

  // Vehicles
  boatsSpawned      Int      @default(0)
  minisSpawned      Int      @default(0)

  // Vehicle Combat
  vehicleKills      Int      @default(0)

  // Fishing
  fishCaught        Int      @default(0)

  // General
  hoursPlayed       Float    @default(0)
  resourcesGathered Int      @default(0)   // total

  // Each player has one stats entry per server per wipe
  @@unique([steamId, serverType, wipeId])
  @@index([steamId])
  @@index([serverType, wipeId])
}

// ============================================
// IDENTITY ANTI-CHEAT
// ============================================

model IdentityFingerprint {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprintHash String
  documentIdHash  String?
  verificationId  String

  @@index([fingerprintHash])
  @@index([documentIdHash])
}

model IdentityFlag {
  id            String             @id @default(cuid())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  flaggedUserId String
  flaggedUser   User               @relation("flaggedUser", fields: [flaggedUserId], references: [id])
  matchedUserId String
  matchedUser   User               @relation("matchedUser", fields: [matchedUserId], references: [id])
  matchType     IdentityMatchType
  status        IdentityFlagStatus @default(PENDING)
  resolvedBy    String?
  resolvedAt    DateTime?
  resolution    String?

  @@index([status])
  @@index([flaggedUserId])
  @@index([matchedUserId])
}

enum IdentityMatchType {
  NAME_DOB
  DOCUMENT_ID
  BOTH
}

enum IdentityFlagStatus {
  PENDING
  CONFIRMED_ALT
  FALSE_POSITIVE
  AUTO_BANNED
}

// ============================================
// GAME ECONOMY ENUMS
// ============================================

enum SeasonStatus {
  UPCOMING
  ACTIVE
  ENDED
  ARCHIVED
}

enum ChallengeType {
  DAILY
  WEEKLY
}

enum ChallengeCategory {
  PVP
  FARMING
  RAIDING
  SURVIVAL
  GENERAL
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum RewardType {
  TOKENS
  XP
  BATTLE_PASS_XP
  COSMETIC
  CASE
  VIP_DAYS
  XP_BOOST
  BADGE
}

enum CosmeticType {
  PROFILE_BADGE
  NAME_COLOR
  WIPE_TITLE
  PROFILE_BANNER
  KILL_EFFECT
  WEAPON_SKIN
  BUILDING_SKIN
}

enum CosmeticRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  SEASONAL
}

enum CaseType {
  BASIC
  RARE
  ELITE
  SEASONAL
}

enum TransactionType {
  EARN_DAILY_LOGIN
  EARN_PLAYTIME
  EARN_PVP_ACHIEVEMENT
  EARN_BATTLE_PASS
  EARN_CHALLENGE
  EARN_EVENT
  EARN_REFUND
  SPEND_CASE_OPEN
  SPEND_SHOP_PURCHASE
  SPEND_SPIN_WHEEL
  ADMIN_GRANT
  ADMIN_DEDUCT
}

enum CreatorTier {
  CREATOR
  PARTNER
}

// ============================================
// SEASON & BATTLE PASS
// ============================================

model Season {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  name      String
  number    Int          @unique
  status    SeasonStatus @default(UPCOMING)
  startsAt  DateTime
  endsAt    DateTime
  maxLevel  Int          @default(50)
  xpPerLevel Json       // { baseXp: number, increase: number }

  // Relations
  tiers         BattlePassTier[]
  playerSeasons PlayerSeason[]
  xpEvents      XpEvent[]
  challenges    ChallengeTemplate[]
  cosmetics     Cosmetic[]
  caseDefinitions CaseDefinition[]
  shopItems     ShopItem[]

  @@index([status])
}

model BattlePassTier {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  seasonId  String
  season    Season     @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  level      Int
  isPremium  Boolean   @default(false)
  rewardType RewardType
  rewardAmount Int?
  cosmeticId String?
  caseDefId  String?

  @@unique([seasonId, level, isPremium])
  @@index([seasonId])
}

model PlayerSeason {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  currentXp     Int      @default(0)
  currentLevel  Int      @default(0)
  hasPremium    Boolean  @default(false)
  claimedLevels Int[]
  lastLoginDate DateTime?
  loginStreak   Int      @default(0)

  @@unique([userId, seasonId])
  @@index([userId])
  @@index([seasonId])
}

model XpEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  amount    Int
  source    String   // e.g. "kill", "headshot", "daily_login", "playtime"
  metadata  Json?

  @@index([userId])
  @@index([seasonId])
  @@index([createdAt])
}

// ============================================
// TOKEN ECONOMY (future)
// ============================================

model TokenBalance {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance     Int    @default(0)
  totalEarned Int    @default(0)
  totalSpent  Int    @default(0)
}

model TokenTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         TransactionType
  amount       Int
  balanceAfter Int
  description  String
  metadata     Json?

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// COSMETICS & INVENTORY (future)
// ============================================

model Cosmetic {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  name        String
  description String?
  imageUrl    String?
  type        CosmeticType
  rarity      CosmeticRarity
  seasonId    String?
  season      Season?       @relation(fields: [seasonId], references: [id])
  isLimited   Boolean       @default(false)
  gameItemId  String?       // Reference to in-game item if applicable

  // Relations
  inventory   PlayerInventory[]

  @@index([type])
  @@index([rarity])
}

model PlayerInventory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  cosmeticId String
  cosmetic   Cosmetic @relation(fields: [cosmeticId], references: [id])

  isEquipped Boolean  @default(false)
  source     String   // e.g. "battle_pass", "case", "shop", "admin"
  sourceId   String?  // Reference to the source record

  @@unique([userId, cosmeticId])
  @@index([userId])
}

// ============================================
// CASES (future)
// ============================================

model CaseDefinition {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?
  imageUrl    String?
  caseType    CaseType
  tokenCost   Int
  isActive    Boolean  @default(true)
  seasonId    String?
  season      Season?  @relation(fields: [seasonId], references: [id])

  // Relations
  contents    CaseContent[]
  openings    CaseOpening[]

  @@index([caseType])
  @@index([isActive])
}

model CaseContent {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())

  caseDefId  String
  caseDef    CaseDefinition @relation(fields: [caseDefId], references: [id], onDelete: Cascade)

  rewardType  RewardType
  cosmeticId  String?
  tokenAmount Int?
  xpAmount    Int?
  vipDays     Int?
  weight      Int           // Higher = more common

  @@index([caseDefId])
}

model CaseOpening {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())

  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  caseDefId  String
  caseDef    CaseDefinition @relation(fields: [caseDefId], references: [id])

  rewardType  RewardType
  cosmeticId  String?
  tokenAmount Int?
  xpAmount    Int?
  vipDays     Int?
  tokenCost   Int

  @@index([userId])
  @@index([caseDefId])
}

// ============================================
// CHALLENGES (future)
// ============================================

model ChallengeTemplate {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  name        String
  description String?
  category    ChallengeCategory
  type        ChallengeType
  statKey     String            // e.g. "kills", "headshots", "resourcesGathered"
  targetValue Int
  rewardType  RewardType
  rewardAmount Int
  seasonId    String?
  season      Season?           @relation(fields: [seasonId], references: [id])
  isActive    Boolean           @default(true)
  minLevel    Int               @default(0)

  // Relations
  playerChallenges PlayerChallenge[]

  @@index([type])
  @@index([isActive])
}

model PlayerChallenge {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  seasonId    String
  templateId  String
  template    ChallengeTemplate @relation(fields: [templateId], references: [id])

  currentValue Int             @default(0)
  targetValue  Int
  startValue   Int             @default(0)
  status       ChallengeStatus @default(ACTIVE)
  assignedAt   DateTime        @default(now())
  expiresAt    DateTime
  completedAt  DateTime?

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// ============================================
// SHOP (future)
// ============================================

model ShopItem {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  name           String
  description    String?
  cosmeticId     String?
  caseDefId      String?
  tokenCost      Int
  isActive       Boolean  @default(true)
  availableFrom  DateTime?
  availableUntil DateTime?
  maxPurchases   Int?
  seasonId       String?
  season         Season?  @relation(fields: [seasonId], references: [id])

  // Relations
  purchases ShopPurchase[]

  @@index([isActive])
}

model ShopPurchase {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id])

  tokenCost  Int

  @@index([userId])
  @@index([shopItemId])
}

// ============================================
// SPIN WHEEL (future)
// ============================================

model SpinWheelConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  tokenCost Int
  isActive  Boolean  @default(true)

  // Relations
  segments SpinWheelSegment[]
  results  SpinWheelResult[]
}

model SpinWheelSegment {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())

  wheelId   String
  wheel     SpinWheelConfig @relation(fields: [wheelId], references: [id], onDelete: Cascade)

  label        String
  rewardType   RewardType
  rewardAmount Int?
  cosmeticId   String?
  weight       Int
  color        String?

  // Relations
  results SpinWheelResult[]

  @@index([wheelId])
}

model SpinWheelResult {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())

  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  wheelId   String
  wheel     SpinWheelConfig @relation(fields: [wheelId], references: [id])

  segmentId String
  segment   SpinWheelSegment @relation(fields: [segmentId], references: [id])

  tokenCost    Int
  rewardType   RewardType
  rewardAmount Int?

  @@index([userId])
  @@index([wheelId])
}

// ============================================
// CREATOR PROGRAM (future)
// ============================================

model Creator {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier            CreatorTier
  twitchUsername   String?
  twitchId        String?     @unique
  queuePriority   Int         @default(0)
  antiSnipe       Boolean     @default(false)
  isActive        Boolean     @default(true)

  @@index([tier])
}

model StreamProtection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  isLive        Boolean  @default(false)
  nameHidden    Boolean  @default(false)
  lastLiveCheck DateTime?
}
